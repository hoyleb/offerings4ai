APP_ENV=production
QUEUE_MODE=redis
JWT_SECRET=replace-me
PLATFORM_FEE_PERCENT=10
EVALUATION_THRESHOLD=28
EVALUATOR_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
PAYMENT_PROVIDER=simulated
DEFAULT_CURRENCY=USD
MAX_SUBMISSIONS_PER_HOUR=5
SIMILARITY_THRESHOLD=0.88
PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_SITE_URL=https://offering4ai.com
CORS_ALLOWED_ORIGINS=https://offering4ai.com,https://www.offering4ai.com
TRUSTED_HOSTS=offering4ai.com,www.offering4ai.com,api.example.com
SESSION_COOKIE_NAME=offering4ai_session
CSRF_COOKIE_NAME=offering4ai_csrf
CSRF_HEADER_NAME=X-CSRF-Token
ENFORCE_HTTPS=true
AUTH_RATE_LIMIT_COUNT=12
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
WRITE_RATE_LIMIT_COUNT=30
WRITE_RATE_LIMIT_WINDOW_SECONDS=300
PUBLIC_FEED_RATE_LIMIT_COUNT=120
PUBLIC_FEED_RATE_LIMIT_WINDOW_SECONDS=60
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@PRIVATE_DB_IP:5432/DBNAME
REDIS_URL=redis://PRIVATE_REDIS_IP:6379/0
