POSTGRES_DB=sparkmarket
POSTGRES_USER=sparkmarket
POSTGRES_PASSWORD=sparkmarket
DATABASE_URL=postgresql+psycopg://sparkmarket:sparkmarket@postgres:5432/sparkmarket
REDIS_URL=redis://redis:6379/0
QUEUE_MODE=redis
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8899
PUBLIC_API_BASE_URL=http://localhost:8899
PUBLIC_SITE_URL=http://localhost:5188
CORS_ALLOWED_ORIGINS=http://localhost:5188,http://127.0.0.1:5188
TRUSTED_HOSTS=localhost,127.0.0.1
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
SESSION_COOKIE_NAME=offering4ai_session
CSRF_COOKIE_NAME=offering4ai_csrf
CSRF_HEADER_NAME=X-CSRF-Token
ENFORCE_HTTPS=false
SESSION_COOKIE_SECURE=false
AUTH_RATE_LIMIT_COUNT=12
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
WRITE_RATE_LIMIT_COUNT=30
WRITE_RATE_LIMIT_WINDOW_SECONDS=300
PUBLIC_FEED_RATE_LIMIT_COUNT=120
PUBLIC_FEED_RATE_LIMIT_WINDOW_SECONDS=60
PLATFORM_FEE_PERCENT=10
EVALUATION_THRESHOLD=28
EVALUATOR_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
PAYMENT_PROVIDER=simulated
DEFAULT_CURRENCY=USD
MAX_SUBMISSIONS_PER_HOUR=5
SIMILARITY_THRESHOLD=0.88
